{
  "buildCommand": "pnpm --filter @workspace/inventory-app run build",
  "installCommand": "pnpm install",
  "outputDirectory": "public",
  "cleanUrls": true,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.py" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
