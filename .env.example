# Copy this file to .env and fill in your values.
# Never commit the real .env to Git.

# --- Required for the FastAPI backend ---
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME

# --- Required for the React frontend (local dev only) ---
# PORT and BASE_PATH are injected automatically by Replit workflows.
# For plain local dev (outside Replit), set them manually:
PORT=5173
BASE_PATH=/

# --- Required for the React frontend in production (Vercel/Netlify) ---
# Set this to your Render backend URL, e.g.:
# VITE_API_URL=https://divine-hindu-api.onrender.com
VITE_API_URL=
